{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vitalini-ai-designer",
  "main": "src/index.js",
  "compatibility_date": "2026-07-20",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vitalini-designer-db",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "DESIGNS",
      "bucket_name": "vitalini-designer-images"
    }
  ],
  "ratelimits": [
    {
      "name": "IMAGE_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 5,
        "period": 60
      }
    }
  ],
  "vars": {
    "OPENAI_IMAGE_MODEL": "gpt-image-2",
    "IMAGE_QUALITY": "medium",
    "ALLOWED_ORIGINS": ""
  }
}
